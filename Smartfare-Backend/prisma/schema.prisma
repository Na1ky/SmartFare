generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       Int       @id @default(autoincrement())
  email                    String    @unique
  passwordHash             String?
  authProvider             String    @default("local")
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  isEmailVerified          Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  profile      UserProfile?
  preference   UserPreference?
  itineraries  Itinerary[]
  favorites    ItineraryFavorite[]
  chatSessions ChatSession[]
  sessions     AuthSession[]

  @@map("User")
}

model AuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     Int
  userAgent  String?
  ipAddress  String?
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@index([lastSeenAt])
  @@map("AuthSession")
}

model ChatSession {
  id            Int           @id @default(autoincrement())
  userId        Int
  title         String? // auto-generated from first message or manual
  mode          String        @default("planner") // 'planner' | 'assistant'
  locationId    Int? // destination context for planner mode
  isActive      Boolean       @default(true)
  isPinned      Boolean       @default(false)
  metadata      Json? // store preferences, itinerary preview, etc
  lastMessageAt DateTime? // for sorting chronologically
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]

  user     User      @relation(fields: [userId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([userId])
  @@index([userId, isPinned])
  @@index([userId, createdAt])
  @@index([lastMessageAt])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  chatId    Int
  role      String   @db.VarChar(20) // 'user' | 'assistant'
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat ChatSession @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
}

model UserProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  name      String?
  surname   String?
  city      String?
  street    String?
  avatarUrl String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  budgetLevelCode    String   @default("MEDIUM")
  travelStyle        String?
  pace               String?
  preferredTransport String?
  prefersNightlife   Boolean?
  familyFriendly     Boolean?
  maxDailyBudget     Decimal?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user                    User                     @relation(fields: [userId], references: [id])
  userPreferenceInterests UserPreferenceInterest[]
}

model UserPreferenceInterest {
  id                 Int @id @default(autoincrement())
  activityCategoryId Int
  preferenceId       Int

  preference UserPreference @relation(fields: [preferenceId], references: [id])
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String
  province  String?
  cap       String?
  latitude  Float
  longitude Float

  accommodations Accommodation[]
  activities     Activity[]
  itineraries    Itinerary[]
  chatSessions   ChatSession[]
}

model Accommodation {
  id         Int     @id @default(autoincrement())
  name       String
  street     String?
  stars      Int     @default(0)
  latitude   Float
  longitude  Float
  imageUrl   String? @default("https://rpcgfwithmoyezrdeahj.supabase.co/storage/v1/object/public/hotels/hotel.avif")
  locationId Int

  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[]
}

model ActivityCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  iconUrl     String?

  activities Activity[]
}

model Activity {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  street      String?
  latitude    Float
  longitude   Float
  imageUrl    String   @default("https://rpcgfwithmoyezrdeahj.supabase.co/storage/v1/object/public/hotels/hotel.avif")
  locationId  Int
  categoryId  Int
  createdAt   DateTime @default(now())

  location       Location         @relation(fields: [locationId], references: [id])
  category       ActivityCategory @relation(fields: [categoryId], references: [id])
  itineraryItems ItineraryItem[]
}

model ItineraryVisibility {
  code        String  @id
  name        String
  description String?

  itineraries Itinerary[]
}

model Itinerary {
  id             Int       @id @default(autoincrement())
  name           String
  description    String?
  isPublished    Boolean   @default(false)
  visibilityCode String    @default("PRIVATE")
  publicSlug     String?   @unique
  startDate      DateTime?
  endDate        DateTime?
  aiPrompt       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         Int?
  locationId     Int?
  imageUrl       String    @default("https://images.trvl-media.com/place/6046257/dfc1097b-fb0b-4d2f-96f5-15d86e72f134.jpg")

  user       User?               @relation(fields: [userId], references: [id])
  location   Location?           @relation(fields: [locationId], references: [id])
  visibility ItineraryVisibility @relation(fields: [visibilityCode], references: [code])
  favorites  ItineraryFavorite[]
  items      ItineraryItem[]

  @@index([userId])
  @@index([updatedAt])
}

model ItineraryFavorite {
  userId      Int
  itineraryId Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  itinerary Itinerary @relation(fields: [itineraryId], references: [id])

  @@id([userId, itineraryId])
}

model ItineraryItemType {
  code        String          @id
  label       String
  description String?
  items       ItineraryItem[]
}

model ItineraryItem {
  id              Int       @id @default(autoincrement())
  itineraryId     Int
  itemTypeCode    String
  dayNumber       Int
  orderInt        Int
  note            String?
  plannedStartAt  DateTime?
  plannedEndAt    DateTime?
  groupName       String?
  groupStartAt    DateTime?
  groupEndAt      DateTime?
  activityId      Int?
  accommodationId Int?

  itinerary     Itinerary         @relation(fields: [itineraryId], references: [id])
  itemType      ItineraryItemType @relation(fields: [itemTypeCode], references: [code])
  activity      Activity?         @relation(fields: [activityId], references: [id])
  accommodation Accommodation?    @relation(fields: [accommodationId], references: [id])

  @@unique([itineraryId, dayNumber, orderInt])
  @@index([itineraryId])
  @@index([activityId])
  @@index([accommodationId])
}
